#!/bin/sh
# Save current time and overlay changes to boot partition
mount -o remount,rw /boot 2>/dev/null

# Save clock
date -u '+%Y-%m-%d %H:%M:%S' > /boot/fake-hwclock.data

# Save overlay (only files that differ from the base system)
UPPER="/tmp/.overlay/upper"
if [ -d "$UPPER" ] && [ "$(ls -A "$UPPER" 2>/dev/null)" ]; then
    tar czf /boot/overlay.gz -C "$UPPER" .
    echo "Overlay saved"
fi

mount -o remount,ro /boot 2>/dev/null
