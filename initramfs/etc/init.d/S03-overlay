#!/bin/sh
# Mount boot partition and apply overlay if present
#
# To persist changes from the running system:
#   mount -o remount,rw /boot
#   tar czf /boot/overlay.tar.gz -C / etc/my-changed-file etc/other-file
#   mount -o remount,ro /boot

case "$1" in
start)
    mkdir -p /boot
    if ! mount -t vfat -o ro /dev/mmcblk0p1 /boot; then
        echo "S03-overlay: could not mount boot partition"
        return 0
    fi

    if [ -f /boot/overlay.gz ]; then
        echo "Applying boot overlay..."
        tar xzf /boot/overlay.gz -C /
    else
        echo "No boot overlay found"
    fi
    ;;
esac
